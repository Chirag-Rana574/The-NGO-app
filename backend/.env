# Database Configuration
DATABASE_URL=

# Redis (Optional - use redis://localhost:6379 or leave as placeholder)
REDIS_URL=redis://localhost:6379

# Twilio Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://permit-butler-inspections-assists.trycloudflare.com/api/whatsapp/webhook

# Security
# Generate secret key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
MASTER_PASSWORD_HASH=

# Medicine Management
# Master key is now set up via the app (POST /auth/setup-key)
# No longer stored in .env

# Time Windows (in minutes/hours)
RESPONSE_WINDOW_MINUTES=60
EXPIRY_CUTOFF_HOURS=24
REMINDER_ADVANCE_MINUTES=15

# Stock Alerts
LOW_STOCK_THRESHOLD=10

# App Settings
TIMEZONE=Asia/Kolkata
DEBUG=True

# Google OAuth (get from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
